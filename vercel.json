{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/out",
  "env": {
    "NEXT_PUBLIC_API_BASE": "/api"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://todo-adventure-backend-production.up.railway.app/api/$1"
    }
  ]
}